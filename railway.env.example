# Variables Railway — AutoChain Emmaus
# Copiez ce fichier dans Railway > tp-laravel > Variables > Raw Editor

APP_ENV=production
APP_DEBUG=false
DB_CONNECTION=mysql
SESSION_DRIVER=database
BLOCKCHAIN_MODE=simulation
NODE_BINARY=node
ALLOW_DEMO_WALLET=false

# Liez MySQL via "Add variable reference" OU copiez depuis MySQL > Variables :
# DB_HOST=${{MySQL.MYSQLHOST}}
# DB_PORT=${{MySQL.MYSQLPORT}}
# DB_DATABASE=${{MySQL.MYSQLDATABASE}}
# DB_USERNAME=${{MySQL.MYSQLUSER}}
# DB_PASSWORD=${{MySQL.MYSQLPASSWORD}}

# APP_KEY et APP_URL sont générés automatiquement au démarrage si absents.
